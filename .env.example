# Default backend is "ollama" (free, local, requires Ollama running with a pulled model).
# Set CLIPPER_LLM_BACKEND=anthropic and fill in ANTHROPIC_API_KEY to use Claude instead.
CLIPPER_LLM_BACKEND=ollama
CLIPPER_OLLAMA_MODEL=llama3.1:8b
CLIPPER_OLLAMA_HOST=http://localhost:11434

ANTHROPIC_API_KEY=
