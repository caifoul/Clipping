# Copy to .env and fill in before running docker compose.

# --- App ---
APP_DOMAIN=localhost
SECRET_KEY=change-me-to-a-long-random-string

# --- Postgres ---
# DATABASE_URL's user/password/db must match the three vars above.
POSTGRES_USER=clipping
POSTGRES_PASSWORD=change-me
POSTGRES_DB=clipping
DATABASE_URL=postgresql+asyncpg://clipping:change-me@postgres:5432/clipping

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- AI providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Storage ---
MEDIA_ROOT=/data/media
